# MQTT Broker Configuration
# HiveMQ Cloud example: your-cluster.s1.eu.hivemq.cloud
MQTT_HOST=your-mqtt-broker-host.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=your_mqtt_username
MQTT_PASS=your_mqtt_password

# Device Configuration
DEVICE_ID=esp32-clock-01

# Gas sensor danger threshold — must match GAS_ALARM_THRESHOLD in ESP32 firmware
GAS_THRESHOLD=400

# WhatsApp Whitelist — comma-separated, international format WITHOUT '+' or spaces
# Example: 6281234567890,6289876543210
# If left empty, ALL senders can trigger commands (development mode only!)
ALLOWED_NUMBERS=

# Puppeteer Configuration (required — set path to your system Chromium/Chrome)
# Arch/Manjaro: /usr/bin/chromium
# Ubuntu/Debian: /usr/bin/chromium-browser
# Google Chrome: /usr/bin/google-chrome-stable
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
